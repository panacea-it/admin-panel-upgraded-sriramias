# Netlify / static production — frontend-only (no localhost API calls)
VITE_FRONTEND_ONLY=true
VITE_ENABLE_DEMO_LOGIN=true
VITE_FINANCE_USE_MOCK=true
VITE_SALES_ANALYTICS_USE_MOCK=true
VITE_BOOKSTORE_USE_MOCK=true
VITE_USE_CLASSROOM_API=false

# Leave VITE_API_BASE_URL unset so axios uses /api only when VITE_FRONTEND_ONLY=false.
# To point at Render in production, set in Netlify UI:
# VITE_FRONTEND_ONLY=false
# VITE_API_BASE_URL=https://new-sriramias.onrender.com
