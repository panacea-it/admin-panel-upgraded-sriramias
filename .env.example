# --- Frontend (Vite) — set in Vercel Project → Environment Variables ---

# Leave unset on Vercel to use same-origin /api (recommended).
# Local dev: proxy target for /api (see vite.config.js)
VITE_API_BASE_URL=http://localhost:5000

# Optional: external API instead of bundled Vercel /api
# VITE_API_BASE_URL=https://your-app.vercel.app

VITE_ENABLE_DEMO_LOGIN=true

# Finance / analytics: use mock data when true
# VITE_FINANCE_USE_MOCK=true
# VITE_SALES_ANALYTICS_USE_MOCK=true

# Classrooms module: set false to force live API only
# VITE_USE_CLASSROOM_API=true
