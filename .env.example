# Production API (default)
# VITE_API_BASE_URL=https://new-sriramias.onrender.com

# Local Courses backend (Node/Express on port 5000)
VITE_API_BASE_URL=http://localhost:5000
# Optional fallback when the server is unreachable (not used for normal login)
# Enable mock RBAC demo accounts (all 7 roles) when API is offline or in dev
VITE_ENABLE_DEMO_LOGIN=true

# Finance module: use mock data when true (default). Set false to use /api/finance backend.
# VITE_FINANCE_USE_MOCK=true
